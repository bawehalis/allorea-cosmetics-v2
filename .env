# ─────────────────────────────────────────────────────────────

# DATABASE

# ─────────────────────────────────────────────────────────────

# Gerçek bağlantı bilgilerini gir (Supabase / Neon / Railway vs)

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Prisma için opsiyonel (connection pooling kullanıyorsan ekle)

# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ─────────────────────────────────────────────────────────────

# AUTH (JWT)

# ─────────────────────────────────────────────────────────────

# Gerçek güçlü key üret: openssl rand -base64 48

JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET_AT_LEAST_48_CHARS_LONG"

# ─────────────────────────────────────────────────────────────

# APP

# ─────────────────────────────────────────────────────────────

# Production'da domain yaz (örn: https://siteadi.com)

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────

# STRIPE

# ─────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY="sk_test_REPLACE"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE"

# ─────────────────────────────────────────────────────────────

# EMAIL (SMTP)

# ─────────────────────────────────────────────────────────────

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="[your-email@gmail.com](mailto:your-email@gmail.com)"
SMTP_PASS="your-app-password"

# ─────────────────────────────────────────────────────────────

# FILE UPLOAD (CLOUDINARY)

# ─────────────────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─────────────────────────────────────────────────────────────

# WHATSAPP ORDER

# ─────────────────────────────────────────────────────────────

# Başında + olmadan yaz

NEXT_PUBLIC_WHATSAPP_NUMBER="905001234567"

# ─────────────────────────────────────────────────────────────

# PAYMENT / SHIPPING

# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_COD_FEE=15
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=299

# ─────────────────────────────────────────────────────────────

# OPTIONAL (ÖNERİLEN)

# ─────────────────────────────────────────────────────────────

# Admin panel güvenliği için ek

ADMIN_EMAIL="[admin@site.com](mailto:admin@site.com)"
ADMIN_PASSWORD="StrongPassword123!"

# Rate limit / güvenlik (opsiyonel)

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
