# ─── Veritabanı ─────────────────────────────────────────────────────────────
# PostgreSQL bağlantı dizesi (Supabase / Neon / Railway / yerel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ─── Kimlik Doğrulama ────────────────────────────────────────────────────────
# Oluşturmak için: openssl rand -base64 48
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars-change-this"

# ─── Uygulama ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── E-posta (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ─── Dosya Yükleme (Cloudinary — isteğe bağlı) ───────────────────────────────
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ─── WhatsApp Sipariş ────────────────────────────────────────────────────────
# Başında + olmadan, sadece rakamlar (örn: 905001234567)
NEXT_PUBLIC_WHATSAPP_NUMBER="905001234567"

# ─── Kapıda Ödeme ────────────────────────────────────────────────────────────
NEXT_PUBLIC_COD_FEE="15"
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD="299"
